# Optional World Bank base URL
WB_BASE_URL=https://api.worldbank.org/v2

# Optional timeout in milliseconds
WB_TIMEOUT_MS=8000

# Required for weather layer
OPENWEATHER_API_KEY=

# Optional OpenWeather base URL
OPENWEATHER_BASE_URL=https://api.openweathermap.org

# Optional timeout in milliseconds
OPENWEATHER_TIMEOUT_MS=8000

# AI summary: mock-first mode for demo/dev
AI_USE_MOCK=true
AI_DEFAULT_LANGUAGE=ru

# Optional real provider settings
AI_PROVIDER=
AI_API_KEY=
AI_MODEL=

# Dataset switching: path to a real listings JSON produced by tools/ingest/restapp-import.ts
# If not set the bundled sample data (listings.sample.json) is used.
# Example: LISTINGS_DATA_PATH=../../data/listings.real.json
LISTINGS_DATA_PATH=
