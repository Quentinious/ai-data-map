# Optional World Bank base URL
WB_BASE_URL=https://api.worldbank.org/v2

# Optional timeout in milliseconds
WB_TIMEOUT_MS=8000

# Required for weather layer
OPENWEATHER_API_KEY=

# Optional OpenWeather base URL
OPENWEATHER_BASE_URL=https://api.openweathermap.org

# Optional timeout in milliseconds
OPENWEATHER_TIMEOUT_MS=8000

# AI summary (new endpoint: POST /v1/ai/summary)
# OFF by default: when false, backend always returns deterministic template summary.
AI_SUMMARY_ENABLED=false

# AI provider settings used only when AI_SUMMARY_ENABLED=true.
# If provider-specific credentials are empty, backend safely falls back to template summary.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Optional alternative providers. Set AI_PROVIDER to one of: openai, gemini, ollama.
# Gemini: requires GEMINI_API_KEY and GEMINI_MODEL.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Ollama: requires OLLAMA_MODEL and optionally OLLAMA_BASE_URL.
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=

# GigaChat (Sberbank): requires GIGACHAT_AUTH_KEY. Set AI_PROVIDER=gigachat to use.
# GIGACHAT_AUTH_KEY is the authorization key for OAuth (not the access_token).
GIGACHAT_AUTH_KEY=
GIGACHAT_MODEL=GigaChat-2-Pro
GIGACHAT_SCOPE=GIGACHAT_API_PERS
GIGACHAT_AUTH_URL=https://ngw.devices.sberbank.ru:9443/api/v2/oauth
GIGACHAT_API_BASE_URL=https://gigachat.devices.sberbank.ru/api/v1

# Legacy AI flags (kept for backward compatibility of old endpoints)
AI_USE_MOCK=false
AI_DEFAULT_LANGUAGE=ru
AI_PROVIDER=openai
AI_API_KEY=
AI_MODEL=

# Dataset switching: path to a real listings JSON produced by tools/ingest/restapp-import.ts
# If not set the bundled sample data (listings.sample.json) is used.
# Example: LISTINGS_DATA_PATH=../../data/listings.real.json
LISTINGS_DATA_PATH=
